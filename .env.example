# ============================================================
# ViralGen AI — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- LLM Providers ---
GROQ_API_KEY=
GEMINI_API_KEY=

# --- Hugging Face (Week 2) ---
HUGGINGFACE_API_TOKEN=

# --- Cloudflare R2 (Week 2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- Upstash Redis / Celery (Week 3) ---
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
CELERY_BROKER_URL=

# --- MongoDB Atlas ---
MONGODB_URI=
MONGODB_DB_NAME=viralgenai

# --- App Config ---
APP_ENV=development
LOG_LEVEL=INFO
